<?xml version="1.0" encoding="utf-8"?>
<!--
  Glasses drawn as a single continuous white brush stroke: from the left temple, up and over the top
  rim, dipping between the two lenses (the nose bridge notch), back up, then sweeping down and out to
  the right temple. Rounded caps give it the hand-drawn, marker-like feel. Sits in the safe zone.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="6.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M30,44
                          C24,44 24,64 34,64
                          C44,64 44,50 52,50
                          C60,50 60,64 68,64
                          C76,64 76,52 84,52" />
    <!-- Top rim: a gentle arc from the left temple across the top of both lenses. -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="6.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M30,44 C34,40 62,40 66,44" />
</vector>
